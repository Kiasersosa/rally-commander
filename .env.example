# Postgres
DATABASE_URL=postgres://rally:rally@localhost:5432/rally_commander

# NextAuth (Auth.js v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-random-32-byte-string
AUTH_URL=http://localhost:3000

# Resend (magic-link email)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Rally Commander <noreply@rallycommander.app>"

# First-deploy bootstrap (creates one team + chief user if no team exists)
RC_BOOTSTRAP_TEAM_NAME="My Rally Team"
RC_BOOTSTRAP_CHIEF_EMAIL=chief@example.com
RC_BOOTSTRAP_CHIEF_NAME="Crew Chief"

# Cloudflare R2 (S3-compatible object storage for documents, road books, receipts)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rally-commander

# Twilio (SMS for time-critical expiry alerts)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567

# Cron endpoint shared secret. Generate with: openssl rand -base64 32
# Set the same value as a GitHub repo secret (CRON_SECRET) so the workflows
# under .github/workflows/cron-*.yml can authenticate.
CRON_SECRET=
